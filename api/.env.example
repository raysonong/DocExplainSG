# DocExplainSG backend configuration.
# Copy to `.env` and fill in. NEVER commit your real .env.

# --- Anthropic Claude (required for analysis) ---
# Get a key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model name — swappable. Default is Sonnet 4.6 (stronger reasoning + vision).
# Alternatives: claude-haiku-4-5 (cheaper/faster), claude-opus-4-8.
# Note: Anthropic's commercial API does not train on your prompts/responses.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-request timeout for the LLM call, in seconds. Keeps a stalled request from
# hanging the app; on timeout the user gets a friendly retry error.
LLM_TIMEOUT_S=45

# --- Upload limits ---
# Maximum total upload size across all files, in megabytes.
MAX_UPLOAD_MB=20
# Maximum number of files (pages/photos) per request.
MAX_FILES=10

# --- CORS ---
# Comma-separated list of allowed origins for the Expo app.
# "*" is convenient for local dev; lock this down for production.
CORS_ORIGINS=*

# --- Server ---
HOST=0.0.0.0
PORT=8000
