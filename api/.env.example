# DocExplainSG backend configuration.
# Copy to `.env` and fill in. NEVER commit your real .env.

# --- Google Gemini (required for Phase 2 onward) ---
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model name — swappable. Default is the free-tier flash model.
# IMPORTANT (see README §Privacy): confirm the free-tier data-usage terms
# before sending real government/financial documents.
GEMINI_MODEL=gemini-3.5-flash

# --- Upload limits ---
# Maximum total upload size across all files, in megabytes.
MAX_UPLOAD_MB=20
# Maximum number of files (pages/photos) per request.
MAX_FILES=10

# --- CORS ---
# Comma-separated list of allowed origins for the Expo app.
# "*" is convenient for local dev; lock this down for production.
CORS_ORIGINS=*

# --- Server ---
HOST=0.0.0.0
PORT=8000
